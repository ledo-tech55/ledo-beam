# =============================================================================
# LEDO-Beam — Frontend Environment Variables
# =============================================================================
# Copy this file to .env (for local dev) or .env.production (for Docker builds)
#
#   cp .env.example .env
#
# VITE_SIGNALING_URL
#   The URL of your C# SignalR signaling backend.
#
#   Local development (Vite dev server proxies this automatically):
#     VITE_SIGNALING_URL=http://localhost:5175/signaling
#
#   Production (when frontend Nginx reverse-proxies to the backend container):
#     VITE_SIGNALING_URL=/signaling
#
# =============================================================================

VITE_SIGNALING_URL=http://localhost:5175/signaling
