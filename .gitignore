# =============================================================================
# LEDO-Beam — Master .gitignore
# Covers: Vite/React Frontend, C# .NET Backend, Docker, IDE, OS
# =============================================================================

# =============================================================================
# Environment & Secrets (CRITICAL — never commit these)
# =============================================================================
.env
.env.*
!.env.example
appsettings.json
appsettings.*.json

# =============================================================================
# Node.js / Vite / React Frontend
# =============================================================================
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.vite/

# =============================================================================
# C# / .NET Backend
# =============================================================================
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
*.user
*.userosscache
*.sln.docstates
*.suo
*.cache
*.dll
*.exe
*.pdb
project.lock.json
*.nuget.props
*.nuget.targets
.nuget/

# =============================================================================
# Visual Studio / JetBrains / VS Code
# =============================================================================
.vs/
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.ntvs*
*.njsproj
*.sw?

# =============================================================================
# Docker & Deployment Artifacts
# =============================================================================
deploy*.zip

# =============================================================================
# OS Generated
# =============================================================================
.DS_Store
Thumbs.db
Desktop.ini
*.tmp
*.bak
*.swp
*~
